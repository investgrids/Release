# Copy this file to .env and fill in real values
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./ig_dev.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://ig:changeme@localhost:5432/investgrids

REDIS_URL=redis://localhost:6379/0

# --- AI Providers (multi-provider fallback chain) ---
# Priority order: OmniRoute → Groq → Cerebras → Gemini → OpenRouter
# Configure at least one. OmniRoute is free/unlimited with no keys required.

# OmniRoute — self-hosted local router (docker-compose sets this automatically)
# Leave blank when running outside Docker; docker-compose injects http://omniroute:20128/v1
OMNIROUTE_URL=

# Groq — free: 14,400 req/day (get key at console.groq.com — takes 30 seconds)
GROQ_API_KEY=

# Cerebras — free: 10,000 req/day, ultra-fast (cloud.cerebras.ai)
CEREBRAS_API_KEY=

# Gemini — free: 1,500 req/day, 4M tokens/day (aistudio.google.com → Get API key)
GEMINI_API_KEY=

# OpenRouter — free models as last-resort fallback (openrouter.ai)
OPENROUTER_API_KEY=

# --- Market Data ---
FINNHUB_API_KEY=

# Fyers — primary real-time market data provider (optional; yfinance used as fallback)
# 1. Create app at https://myapi.fyers.in/dashboard
# 2. Get FYERS_CLIENT_ID (e.g. "XXXXXXXXXX-100") and FYERS_SECRET_KEY
# 3. Run the app, visit GET /api/data/auth/fyers to get the auth URL
# 4. Login via that URL; Fyers redirects with ?code=AUTH_CODE
# 5. POST to /api/data/auth/fyers/callback?auth_code=AUTH_CODE to get access_token
# 6. Set FYERS_ACCESS_TOKEN below (or let the callback handler store it in Redis)
FYERS_CLIENT_ID=
FYERS_SECRET_KEY=
FYERS_ACCESS_TOKEN=
FYERS_REDIRECT_URI=https://127.0.0.1:8000/api/data/auth/callback

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
# Prod: BACKEND_CORS_ORIGINS=["https://yourdomain.com"]

# --- Logging ---
LOG_LEVEL=INFO
JSON_LOGS=false
# Prod: JSON_LOGS=true
